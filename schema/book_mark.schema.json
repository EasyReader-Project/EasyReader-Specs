{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://easyreader.project/schemas/book_mark.schema.json",
  "title": "书签/高亮数据",
  "description": "用户标记的阅读位置，包含定位、高亮文本和样式",
  "type": "object",
  "required": [
    "location",
    "style",
    "created_at"
  ],
  "properties": {
    "location": {
      "type": "object",
      "description": "精确定位，结构与 progress 中的 location 完全一致",
      "properties": {
        "epub": {
          "type": "object",
          "properties": {
            "cfi": {
              "type": "string",
              "pattern": "^epubcfi\\(.*\\)$"
            }
          },
          "required": [
            "cfi"
          ],
          "additionalProperties": false
        },
        "pdf": {
          "type": "object",
          "properties": {
            "page": {
              "type": "integer",
              "minimum": 1
            }
          },
          "required": [
            "page"
          ],
          "additionalProperties": false
        }
      },
      "additionalProperties": false,
      "minProperties": 1,
      "maxProperties": 1
    },
    "name": {
      "type": "string",
      "description": "用户自定义名称（可选）"
    },
    "selected_text": {
      "type": "string",
      "description": "选中的高亮文本（纯文本）"
    },
    "color": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$",
      "description": "高亮颜色，十六进制格式，如 #FFCC00"
    },
    "style": {
      "type": "string",
      "enum": [
        "bookmark",
        "highlight",
        "underline"
      ],
      "description": "样式类型：仅书签 / 背景高亮 / 下划线"
    },
    "chapter_title": {
      "type": "string",
      "description": "冗余字段：当前所在章节标题，便于列表展示"
    },
    "created_at": {
      "type": "integer",
      "description": "创建时间戳（毫秒）"
    },
    "updated_at": {
      "type": "integer",
      "description": "更新时间戳（毫秒）"
    }
  },
  "additionalProperties": false
}